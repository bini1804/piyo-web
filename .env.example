# ===========================================
# Piyo Web — Environment Variables
# ===========================================
# cp .env.example .env.local → 실제 값 입력
# .env.local은 절대 git에 커밋하지 않음
# ===========================================

# ----- Supabase (순수 DB로만 사용, Auth 미사용) -----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- NextAuth v5 (Auth.js) -----
# 앱 공개 URL (OAuth 콜백·리디렉트). 프로덕션에서는 실제 도메인으로.
AUTH_URL=http://localhost:3000
# 선택: 클라 번들이 NEXTAUTH_URL만 읽는 경우가 있어 AUTH_URL과 동일하게 맞추면 안전
# NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=generate-with-npx-auth-secret

# ----- Kakao OAuth -----
AUTH_KAKAO_ID=your-kakao-rest-api-key
AUTH_KAKAO_SECRET=your-kakao-client-secret

# ----- Google OAuth -----
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# ----- Naver OAuth (선택, AUTH_NAVER_ID 없으면 provider 미등록) -----
AUTH_NAVER_ID=
AUTH_NAVER_SECRET=

# ----- Piyo Backend -----
PIYO_API_URL=http://your-server:8512
PIYO_API_KEY=
# 선택: 백엔드 fetch 타임아웃(ms). 기본 110000
# PIYO_FETCH_TIMEOUT_MS=110000

# ----- Mock Mode (백엔드 없이 테스트) -----
# true로 설정하면 목 데이터로 응답
NEXT_PUBLIC_MOCK_MODE=true

# ----- Rate Limiting -----
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_MS=60000
