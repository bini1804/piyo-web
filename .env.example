# ===========================================
# Piyo Web — Environment Variables
# ===========================================
# cp .env.example .env.local → 실제 값 입력
# .env.local은 절대 git에 커밋하지 않음
# ===========================================

# ----- Supabase (순수 DB로만 사용, Auth 미사용) -----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----- NextAuth v5 (Auth.js) -----
# 앱 공개 URL (OAuth 콜백·리디렉트). 프로덕션에서는 실제 도메인으로.
AUTH_URL=http://localhost:3000
# 선택: 클라 번들이 NEXTAUTH_URL만 읽는 경우가 있어 AUTH_URL과 동일하게 맞추면 안전
# NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=generate-with-npx-auth-secret

# ----- Kakao OAuth -----
AUTH_KAKAO_ID=your-kakao-rest-api-key
AUTH_KAKAO_SECRET=your-kakao-client-secret

# ----- Google OAuth -----
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# ----- Naver OAuth (선택, AUTH_NAVER_ID 없으면 provider 미등록) -----
AUTH_NAVER_ID=
AUTH_NAVER_SECRET=

# ----- RDS / S3 미디어 (선택) -----
# DB banner_images 가 상대경로만 담는 경우, 앱과 같은 S3/CloudFront 베이스 URL (끝에 / 없이)
# 예: https://your-bucket.s3.ap-northeast-2.amazonaws.com  또는 CloudFront 도메인
# NEXT_PUBLIC_RDS_MEDIA_BASE_URL=https://your-cdn.example.com

# ----- Spring (YouAre365 병원 상세 GET /api/hospital/{id}) -----
# MEMBER JWT(Bearer). 서버 컴포넌트·generateMetadata에서만 사용 — NEXT_PUBLIC 금지.
# YOUARE365_SPRING_API_URL=https://api.example.com
# YOUARE365_SPRING_BEARER=eyJ...

# ----- Piyo Backend (FastAPI: POST /chat/v2) -----
# 로컬: 둘 중 하나 이상에 베이스 URL만 (끝 슬래시 없이). Next API는 PIYO_API_URL을 먼저 읽고, 없으면 NEXT_PUBLIC_PIYO_API_URL 사용.
# 병원 상세: FastAPI에 GET /hospital/{id}가 있으면 Spring보다 우선 시도(선택).
# PIYO_API_URL=http://localhost:8512
NEXT_PUBLIC_PIYO_API_URL=http://localhost:8512
PIYO_API_KEY=
# 선택: 백엔드 fetch 타임아웃(ms). 기본 110000
# PIYO_FETCH_TIMEOUT_MS=110000

# ----- Rate Limiting -----
RATE_LIMIT_MAX_REQUESTS=30
RATE_LIMIT_WINDOW_MS=60000
